{
  "name": "elder",
  "display_name": "老年人模式",
  "version": "5.0.0",
  "description": "简化配置向导，适合不熟悉工具的用户",
  "load_timing": "on_demand",
  "nav_button": {
    "show": true,
    "id": "elder-btn",
    "icon": "fas fa-compass",
