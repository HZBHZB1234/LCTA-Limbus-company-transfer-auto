    { "path": "elder.character.base", "label": "基础", "type": "boolean", "default": true },
    { "path": "elder.character.launcher", "label": "启动器", "type": "boolean", "default": true },
    { "path": "elder.character.translate", "label": "翻译", "type": "boolean", "default": true },
    { "path": "elder.character.manage", "label": "管理", "type": "boolean", "default": true },
    { "path": "elder_list", "label": "老年人列表", "type": "string", "default": "[]" }
  ],
  "js_modules": ["page.js"],
  "css_modules": [],
  "requires": [],
  "conflicts": []
